<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Transport Gap Fill</title>
<style>
  :root{
    --bg1:#e8f4ff;
    --bg2:#fef6e4;
    --card:#ffffff;
    --blue:#0a58ca;
    --red:#e63946;
    --navy:#1d3557;
    --yellow:#ffd166;
    --green:#2a9d8f;
    --shadow:0 16px 40px rgba(29,53,87,.15);
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:
      radial-gradient(circle at top left, #ffffff 0%, var(--bg1) 38%, transparent 39%),
      radial-gradient(circle at bottom right, #fff8e8 0%, var(--bg2) 34%, transparent 35%),
      linear-gradient(135deg, #f5fbff 0%, #eef7ff 45%, #fff9ef 100%);
    min-height:100vh;
    color:#243447;
  }
  .wrap{
    max-width:900px;
    margin:32px auto;
    padding:24px;
  }
  .card{
    background:var(--card);
    border-radius:24px;
    box-shadow:var(--shadow);
    overflow:hidden;
    border:1px solid rgba(10,88,202,.08);
  }
  .hero{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:24px;
    padding:28px 28px 18px 28px;
    background:linear-gradient(135deg, #dff0ff 0%, #f6fbff 45%, #fff4d8 100%);
    border-bottom:1px solid rgba(10,88,202,.08);
  }
  .hero-text{
    flex:1 1 320px;
  }
  .badge{
    display:inline-block;
    background:#ffffff;
    color:var(--blue);
    border:2px solid #b7d7ff;
    border-radius:999px;
    padding:6px 12px;
    font-weight:700;
    letter-spacing:.2px;
    margin-bottom:10px;
  }
  h1{
    margin:0 0 10px 0;
    color:var(--navy);
    font-size:34px;
    line-height:1.1;
  }
  .subtitle{
    margin:0;
    font-size:18px;
    color:#38506b;
  }
  .hero-art{
    flex:0 0 280px;
    max-width:280px;
    margin-left:auto;
  }
  .task{
    padding:28px;
  }
  .instruction{
    background:#f3f9ff;
    border-left:6px solid var(--blue);
    padding:14px 16px;
    border-radius:14px;
    margin-bottom:22px;
    line-height:1.5;
    font-size:18px;
  }
  .line{
    font-size:21px;
    line-height:1.85;
    margin:14px 0;
    padding:12px 14px;
    border-radius:16px;
    background:linear-gradient(90deg, rgba(10,88,202,.04), rgba(42,157,143,.04));
  }
  input{
    width:155px;
    max-width:100%;
    font-size:18px;
    padding:10px 12px;
    border:2px solid #bdd8ff;
    border-radius:12px;
    outline:none;
    background:#fff;
    transition:.2s ease;
    margin:0 4px;
  }
  input:focus{
    border-color:var(--blue);
    box-shadow:0 0 0 4px rgba(10,88,202,.12);
  }
  .controls{
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    margin-top:22px;
  }
  button{
    border:none;
    border-radius:14px;
    padding:13px 18px;
    font-size:17px;
    font-weight:700;
    cursor:pointer;
    transition:transform .08s ease, box-shadow .2s ease, opacity .2s ease;
  }
  button:hover{transform:translateY(-1px)}
  .check{
    background:linear-gradient(135deg, var(--blue), #4da3ff);
    color:white;
    box-shadow:0 10px 24px rgba(10,88,202,.22);
  }
  .reset{
    background:linear-gradient(135deg, #ffd166, #ffb703);
    color:#4a3500;
    box-shadow:0 10px 24px rgba(255,183,3,.24);
  }
  .result{
    margin-top:20px;
    padding:16px 18px;
    border-radius:16px;
    font-size:20px;
    font-weight:700;
    display:none;
  }
  .good{
    background:#e8fbf2;
    color:#166b52;
    border:2px solid #b6edd8;
  }
  .mid{
    background:#fff7dd;
    color:#7b5a00;
    border:2px solid #ffe08a;
  }
  .low{
    background:#ffe8ea;
    color:#9c2330;
    border:2px solid #ffbcc4;
  }
  @media (max-width:700px){
    h1{font-size:28px}
    .line{font-size:18px}
    input{width:130px}
    .hero-art{max-width:100%; flex:1 1 100%}
  }
</style>
<script type="text/javascript" nonce="1c4fb599be0546629157cb8291a" src="//local.adguard.org?ts=1776838854071&amp;type=content-script&amp;dmn=chatgpt.com&amp;url=https%3A%2F%2Fchatgpt.com%2Fbackend-api%2Festuary%2Fcontent%3Fid%3Dfile_0000000028a87246a8ad4b3ccba55d5f%26ts%3D493567%26p%3Dfs%26cid%3D1%26sig%3D1ee0f907ddf48bed51014da9a08ff8598f6a9ca2e9f3162d5687843fd70d838a%26v%3D0&amp;app=chrome.exe&amp;css=2&amp;js=1&amp;rel=1&amp;rji=1&amp;sbe=1"></script><script type="text/javascript" nonce="1c4fb599be0546629157cb8291a" src="//local.adguard.org?ts=1776838854071&amp;name=AdGuard%20Extra&amp;name=AdGuard%20Popup%20Blocker&amp;type=user-script"></script></head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="hero">
        <div class="hero-text">
          <div class="badge">London Transport</div>
          <h1>TfL Gap Fill</h1>
          <p class="subtitle">Public transport in London</p>
        </div>

        <div class="hero-art" aria-label="TfL illustration">
          <svg viewBox="0 0 320 220" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="busGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#ff5a67"/>
                <stop offset="100%" stop-color="#d7263d"/>
              </linearGradient>
              <linearGradient id="sky" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#eaf6ff"/>
                <stop offset="100%" stop-color="#fff6de"/>
              </linearGradient>
            </defs>
            <rect x="0" y="0" width="320" height="220" rx="24" fill="url(#sky)"/>
            <circle cx="160" cy="80" r="50" fill="none" stroke="#0a58ca" stroke-width="18"/>
            <rect x="74" y="70" width="172" height="20" rx="10" fill="#e63946"/>
            <text x="160" y="86" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="26" font-weight="700" fill="#1d3557">TfL</text>

            <rect x="45" y="122" width="230" height="58" rx="16" fill="url(#busGrad)" />
            <rect x="62" y="134" width="52" height="20" rx="4" fill="#dff0ff"/>
            <rect x="118" y="134" width="52" height="20" rx="4" fill="#dff0ff"/>
            <rect x="174" y="134" width="52" height="20" rx="4" fill="#dff0ff"/>
            <rect x="230" y="134" width="28" height="34" rx="4" fill="#ffe5e8"/>
            <circle cx="95" cy="184" r="12" fill="#1d3557"/>
            <circle cx="230" cy="184" r="12" fill="#1d3557"/>
            <rect x="58" y="158" width="120" height="8" rx="4" fill="#ffd166"/>
            <path d="M18 192 H300" stroke="#7aa0c8" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </div>
      </div>

      <div class="task">
        <div class="instruction">
          <strong>Complete the sentences about using public transport in London.</strong>
        </div>

        <div class="line">You need to <input id="q1" autocomplete="off"> at the beginning of your journey.</div>
        <div class="line">You need to <input id="q2" autocomplete="off"> at the end of your journey.</div>
        <div class="line">Make <input id="q3" autocomplete="off"> you use the same <input id="q4" autocomplete="off"> method.</div>
        <div class="line">When you are <input id="q5" autocomplete="off"> on the bus or a tram, you only need to <input id="q6" autocomplete="off"> once.</div>
        <div class="line">Use the same payment method to be included in the £1.75 bus <input id="q7" autocomplete="off">.</div>

        <div class="controls">
          <button class="check" onclick="checkAnswers()">Check Answers</button>
          <button class="reset" onclick="resetTask()">Reset</button>
        </div>

        <div id="result" class="result"></div>
      </div>
    </div>
  </div>

<script>
const answers = {
  q1: "tap in",
  q2: "tap out",
  q3: "sure",
  q4: "payment",
  q5: "getting",
  q6: "tap",
  q7: "fare"
};

function normalize(text){
  return text.toLowerCase().trim().replace(/\s+/g, ' ');
}

function checkAnswers(){
  let score = 0;
  for (const key in answers){
    const field = document.getElementById(key);
    const user = normalize(field.value);
    const right = normalize(answers[key]);

    if(user === right){
      score++;
      field.style.borderColor = "#2a9d8f";
      field.style.background = "#ecfff7";
    } else {
      field.style.borderColor = "#e63946";
      field.style.background = "#fff1f3";
    }
  }

  const result = document.getElementById("result");
  result.style.display = "block";
  result.className = "result";

  if(score === 7){
    result.classList.add("good");
    result.innerHTML = "Excellent. Score: " + score + "/7";
  } else if(score >= 4){
    result.classList.add("mid");
    result.innerHTML = "Good try. Score: " + score + "/7";
  } else {
    result.classList.add("low");
    result.innerHTML = "Try again. Score: " + score + "/7";
  }
}

function resetTask(){
  for (const key in answers){
    const field = document.getElementById(key);
    field.value = "";
    field.style.borderColor = "#bdd8ff";
    field.style.background = "#fff";
  }
  const result = document.getElementById("result");
  result.style.display = "none";
  result.innerHTML = "";
  result.className = "result";
}
</script>
</body>
</html>
